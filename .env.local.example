# Email Configuration
# ==================

# For Gmail:
# 1. Enable 2-Step Verification: https://support.google.com/accounts/answer/185839
# 2. Generate App Password: https://support.google.com/accounts/answer/185833
# 3. Use the generated App Password below

# For Mailtrap:
# 1. Sign up at https://mailtrap.io
# 2. Get credentials from Integrations > Nodemailer

# For SendGrid:
# 1. Sign up at https://sendgrid.com
# 2. Create an API key

EMAIL_SERVICE="gmail"
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-specific-password"

# Alternative for Mailtrap:
# EMAIL_SERVICE="mailtrap"
# EMAIL_USER="your-mailtrap-username"
# EMAIL_PASSWORD="your-mailtrap-password"

# Alternative for SendGrid:
# EMAIL_SERVICE="sendgrid"
# SENDGRID_API_KEY="your-sendgrid-api-key"
